# Copy this file to .deploy.env and fill in your values.
#   cp .deploy.env.example .deploy.env
# .deploy.env is gitignored — these aren't secrets, but they're per-deployment.

# The S3 bucket that holds the built site (must be globally unique).
BUCKET=celebrate-kristinallen-com

# The subdomain to serve, and the root domain whose Route 53 zone it lives in.
# Used by setup-aws.sh to provision the cert + DNS.
SITE_DOMAIN=celebrate.kristinallen.com
ROOT_DOMAIN=kristinallen.com

# The CloudFront distribution in front of that bucket (for HTTPS + the custom
# domain). Leave blank — setup-aws.sh fills this in automatically. Until it's
# set, deploy.sh simply skips the cache-invalidation step.
DISTRIBUTION_ID=

# ── Capture backend wiring (fill in after `sam deploy`) ──────────────────────
# deploy.sh exports everything here into the build, and the share form reads
# these PUBLIC_ vars. Until they're set, the form runs in harmless preview mode.
# Both point at the Lambda Function URL (from the sam deploy output) + a path.
#   e.g. https://abc123.lambda-url.us-east-1.on.aws/presign
PUBLIC_PRESIGN_API=
PUBLIC_SUBMIT_API=
# Real Cloudflare Turnstile site key for production spam protection (optional).
PUBLIC_TURNSTILE_SITE_KEY=
