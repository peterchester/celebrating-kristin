node_modules/
dist/
.astro/
.DS_Store
*.log

# Keep originals + private capture data out of the repo
originals/
capture/.env
capture/private/
*.private.json

# Per-deployment config for deploy.sh (bucket + distribution id)
.deploy.env

# AWS SAM build output + deploy config (samconfig.toml may hold secrets)
.aws-sam/
samconfig.toml

# Ignore USER-GENERATED content only — submitted entries and uploaded media live
# in the live store / locally, and are assembled into the static build at deploy
# ("freeze") time. One example entry is kept so the repo builds on a fresh clone.
# Theme/design assets (public/img/*) are committed like any other code.
src/content/entries/*.json
!src/content/entries/2026-06-14-example.json
public/media/*
!public/media/2026-06-14-example/
# Local-dev capture output (the mock writes here; mirrors what the Lambda writes
# to S3). Submitting locally or hand-adding files here is fine — never committed.
public/entries/
public/data/
public/comments/
