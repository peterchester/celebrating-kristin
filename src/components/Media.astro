---
// Renders a single media attachment. Captions/alt are passed through Astro's
// auto-escaping, so user-submitted text can't inject markup.
interface Props {
  type: 'image' | 'audio' | 'video';
  src: string;
  caption?: string;
  alt?: string;
}
const { type, src, caption, alt } = Astro.props;
---

<figure class="media">
  {type === 'image' && <img src={src} alt={alt ?? caption ?? ''} loading="lazy" />}
  {type === 'audio' && <audio controls preload="none" src={src}></audio>}
  {type === 'video' && <video controls preload="metadata" playsinline src={src}></video>}
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .media { margin: 1.5rem 0; }
  .media img, .media video { width: 100%; height: auto; border-radius: 6px; display: block; }
  .media audio { width: 100%; }
  figcaption { color: var(--soft); font-size: .9rem; font-style: italic; margin-top: .5rem; text-align: center; }
</style>
