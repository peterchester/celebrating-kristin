---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const entries = (await getCollection('entries'))
  .filter((e) => e.data.status !== 'hidden')
  .sort((a, b) => b.data.submittedAt.getTime() - a.data.submittedAt.getTime());

const excerpt = (body: string) => {
  const first = body.split(/\n\s*\n/)[0].trim();
  return first.length > 240 ? first.slice(0, 240).trimEnd() + '…' : first;
};
---

<Base>
  <header class="site hero">
    <div class="hero-text">
      <h1>Remembering Kristin</h1>
      <p>A place to gather stories, reflections, and anything else that we might want to revisit in the years to come.</p>
      <a class="share-cta" href="/share">Share a memory</a>
    </div>
  </header>

  <main class="wrap">
    {entries.length === 0 && <p class="empty">No memories yet. <a href="/share">Be the first to share one.</a></p>}

    <ul class="entries">
      {entries.map((e) => (
        <li>
          <a class="card" href={`/entry/${e.id}`}>
            {e.data.media[0]?.type === 'image' && (
              <img class="thumb" src={e.data.media[0].src} alt={e.data.media[0].alt ?? ''} loading="lazy" />
            )}
            <div class="card-body">
              {e.data.title && <h2>{e.data.title}</h2>}
              <p class="byline">{e.data.author.name}{e.data.author.relationship && <span> · {e.data.author.relationship}</span>}</p>
              <p class="excerpt">{excerpt(e.data.body)}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Base>

<style>
  /* Photo hero — Kristin sits on the left of the image, so the text floats over
     the open space on the right. A diagonal scrim keeps it legible over the fog. */
  .site.hero {
    position: relative;
    min-height: min(80vh, 760px);
    display: flex;
    align-items: center;
    padding: 0;
    border-bottom: none;
    background-image:
      linear-gradient(105deg, rgba(28,24,20,0) 38%, rgba(28,24,20,0.42) 70%, rgba(28,24,20,0.62) 100%),
      url('/img/header.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .hero-text {
    margin-left: auto;
    max-width: 30rem;
    padding: 2rem clamp(1.25rem, 5vw, 4rem);
    text-align: right;
    color: #fff;
  }
  .hero-text h1 {
    font-weight: 400;
    font-size: clamp(2.3rem, 6vw, 3.4rem);
    line-height: 1.1;
    letter-spacing: .01em;
    margin: 0 0 .6rem;
    text-shadow: 0 1px 24px rgba(0,0,0,.4);
  }
  .hero-text p {
    margin: 0 0 1.5rem;
    color: rgba(255,255,255,.94);
    font-style: italic;
    text-shadow: 0 1px 12px rgba(0,0,0,.45);
  }
  .hero-text .share-cta { box-shadow: 0 4px 18px rgba(0,0,0,.25); }

  /* On narrow screens the image crops to a portrait; keep Kristin in frame and
     move the text to the bottom over a vertical scrim so it always reads. */
  @media (max-width: 640px) {
    .site.hero {
      min-height: 72vh;
      align-items: flex-end;
      background-position: 32% center;
      background-image:
        linear-gradient(to bottom, rgba(28,24,20,0) 30%, rgba(28,24,20,0.35) 60%, rgba(28,24,20,0.72) 100%),
        url('/img/header.jpg');
    }
    .hero-text {
      margin: 0;
      max-width: none;
      width: 100%;
      text-align: center;
      padding-bottom: 2.5rem;
    }
  }

  main { padding-top: 2.5rem; }
  .empty { text-align: center; color: var(--soft); }
  .entries { list-style: none; padding: 0; margin: 0; display: grid; gap: 1.5rem; }
  .card { display: block; text-decoration: none; color: inherit; border: 1px solid var(--line); border-radius: 10px; overflow: hidden; background: #fff; transition: box-shadow .15s ease, transform .15s ease; }
  .card:hover { box-shadow: 0 6px 24px rgba(0,0,0,.07); transform: translateY(-2px); }
  .thumb { width: 100%; height: 220px; object-fit: cover; display: block; }
  .card-body { padding: 1.25rem 1.5rem 1.5rem; }
  .card h2 { margin: 0 0 .25rem; font-weight: 400; font-size: 1.5rem; }
  .byline { margin: 0 0 .6rem; color: var(--soft); font-size: .9rem; font-family: -apple-system, system-ui, sans-serif; }
  .excerpt { margin: 0; }
</style>
