---
import Base from '../layouts/Base.astro';
// The gallery is rendered in the browser from /data/index.json (written by the
// capture backend), so a new memory appears the moment it's submitted — no
// rebuild. Card markup + styles come from src/lib/render.ts + styles/content.css.
---

<Base>
  <header class="site hero">
    <div class="hero-text">
      <h1>Celebrating Kristin</h1>
      <p>A place to gather stories, reflections, and anything else that we might want to revisit in the years to come.</p>
      <a class="share-cta" href="/share">Share a memory</a>
    </div>
  </header>

  <main class="wrap">
    <p class="empty" hidden>No memories yet. <a href="/share">Be the first to share one.</a></p>
    <div class="masonry" aria-live="polite"></div>
  </main>
</Base>

<script>
  import { cardHTML } from '../lib/render';

  const masonry = document.querySelector('.masonry');
  const empty = document.querySelector('.empty');

  async function load() {
    try {
      const res = await fetch('/data/index.json', { cache: 'no-store' });
      const entries = res.ok ? await res.json() : [];
      entries.sort((a, b) => String(b.submittedAt || '').localeCompare(String(a.submittedAt || '')));
      if (!entries.length) {
        if (empty) (empty as HTMLElement).hidden = false;
        return;
      }
      if (masonry) masonry.innerHTML = entries.map(cardHTML).join('');
    } catch {
      if (empty) (empty as HTMLElement).hidden = false;
    }
  }
  load();
</script>

<style>
  /* Photo hero — Kristin sits on the left of the image, so the text floats over
     the open space on the right. A diagonal scrim keeps it legible over the fog. */
  .site.hero {
    position: relative;
    min-height: min(80vh, 760px);
    display: flex;
    align-items: center;
    padding: 0;
    border-bottom: none;
    overflow: hidden;
  }
  .site.hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url('/img/header.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    -webkit-mask-image:
      linear-gradient(115deg, #000 24%, rgba(0, 0, 0, 0.82) 52%, rgba(0, 0, 0, 0.4) 80%, rgba(0, 0, 0, 0) 100%),
      linear-gradient(to bottom, #000 66%, rgba(0, 0, 0, 0.4) 90%, rgba(0, 0, 0, 0) 100%);
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(115deg, #000 24%, rgba(0, 0, 0, 0.82) 52%, rgba(0, 0, 0, 0.4) 80%, rgba(0, 0, 0, 0) 100%),
      linear-gradient(to bottom, #000 66%, rgba(0, 0, 0, 0.4) 90%, rgba(0, 0, 0, 0) 100%);
    mask-composite: intersect;
  }
  .hero-text {
    position: relative;
    z-index: 1;
    margin-left: auto;
    max-width: min(92vw, 46rem);
    padding: 2rem clamp(1.25rem, 5vw, 4rem);
    text-align: right;
    color: #fff;
  }
  .hero-text h1 {
    font-weight: 400;
    font-size: clamp(2.6rem, 7.5vw, 5.6rem);
    line-height: .95;
    letter-spacing: .01em;
    margin: 0 0 .6rem;
    text-shadow: 0 1px 24px rgba(0,0,0,.4);
  }
  .hero-text p {
    /* The title can use the full (wide) hero box, but keep the lede at a
       comfortable reading width, right-aligned within it. */
    max-width: 30rem;
    margin: 0 0 1.5rem auto;
    color: rgba(255,255,255,.94);
    font-style: italic;
    text-shadow: 0 1px 12px rgba(0,0,0,.45);
  }
  .hero-text .share-cta { box-shadow: 0 4px 18px rgba(0,0,0,.25); }

  @media (max-width: 640px) {
    .site.hero { min-height: 72vh; align-items: flex-end; }
    .site.hero::before {
      background-position: 32% center;
      -webkit-mask-image: linear-gradient(to bottom, #000 28%, rgba(0, 0, 0, 0.55) 68%, rgba(0, 0, 0, 0) 100%);
              mask-image: linear-gradient(to bottom, #000 28%, rgba(0, 0, 0, 0.55) 68%, rgba(0, 0, 0, 0) 100%);
    }
    .hero-text { margin: 0; max-width: none; width: 100%; text-align: center; padding-bottom: 2.5rem; }
    .hero-text h1 { font-size: 3.64rem; } /* ~40% larger than the 2.6rem clamp floor */
    .hero-text p { max-width: none; margin-inline: auto; } /* center the lede on mobile */
  }

  /* Mid widths: keep the hero block a bit narrower so it doesn't sprawl. */
  @media (min-width: 641px) and (max-width: 1070px) {
    .hero-text { max-width: min(82vw, 42rem); }
    .hero-text p { max-width: 24rem; }
  }

  main { padding-top: 2.5rem; max-width: 1020px; }
  .empty { text-align: center; color: var(--soft); }

  /* Masonry via CSS columns — no JS, handles varying card heights, and cards
     never split across columns (break-inside: avoid lives on .card). */
  .masonry { column-width: 19rem; column-gap: 1.25rem; }
  .masonry > :global(.card) { margin: 0 0 1.25rem; }

  @media (min-width: 1021px) {
    main { max-width: none; }
    .masonry { column-width: auto; column-count: 4; }
  }
</style>
