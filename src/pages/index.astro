---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import MemoryCard from '../components/MemoryCard.astro';

const entries = (await getCollection('entries'))
  .filter((e) => e.data.status !== 'hidden')
  .sort((a, b) => b.data.submittedAt.getTime() - a.data.submittedAt.getTime());
---

<Base>
  <header class="site hero">
    <div class="hero-text">
      <h1>Celebrating Kristin</h1>
      <p>A place to gather stories, reflections, and anything else that we might want to revisit in the years to come.</p>
      <a class="share-cta" href="/share">Share a memory</a>
    </div>
  </header>

  <main class="wrap">
    {entries.length === 0 && <p class="empty">No memories yet. <a href="/share">Be the first to share one.</a></p>}

    <div class="masonry">
      {entries.map((e) => <MemoryCard entry={e} />)}
    </div>
  </main>
</Base>

<style>
  /* Photo hero — Kristin sits on the left of the image, so the text floats over
     the open space on the right. A diagonal scrim keeps it legible over the fog. */
  .site.hero {
    position: relative;
    min-height: min(80vh, 760px);
    display: flex;
    align-items: center;
    padding: 0;
    border-bottom: none;
    background-image:
      linear-gradient(105deg, rgba(28,24,20,0) 38%, rgba(28,24,20,0.42) 70%, rgba(28,24,20,0.62) 100%),
      url('/img/header.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .hero-text {
    margin-left: auto;
    max-width: 30rem;
    padding: 2rem clamp(1.25rem, 5vw, 4rem);
    text-align: right;
    color: #fff;
  }
  .hero-text h1 {
    font-weight: 400;
    font-size: clamp(2.3rem, 6vw, 3.4rem);
    line-height: 1.1;
    letter-spacing: .01em;
    margin: 0 0 .6rem;
    text-shadow: 0 1px 24px rgba(0,0,0,.4);
  }
  .hero-text p {
    margin: 0 0 1.5rem;
    color: rgba(255,255,255,.94);
    font-style: italic;
    text-shadow: 0 1px 12px rgba(0,0,0,.45);
  }
  .hero-text .share-cta { box-shadow: 0 4px 18px rgba(0,0,0,.25); }

  /* On narrow screens the image crops to a portrait; keep Kristin in frame and
     move the text to the bottom over a vertical scrim so it always reads. */
  @media (max-width: 640px) {
    .site.hero {
      min-height: 72vh;
      align-items: flex-end;
      background-position: 32% center;
      background-image:
        linear-gradient(to bottom, rgba(28,24,20,0) 30%, rgba(28,24,20,0.35) 60%, rgba(28,24,20,0.72) 100%),
        url('/img/header.jpg');
    }
    .hero-text {
      margin: 0;
      max-width: none;
      width: 100%;
      text-align: center;
      padding-bottom: 2.5rem;
    }
  }

  /* Up to 1020px: capped width, cards reflow 1→2→3 columns (the look we like). */
  main { padding-top: 2.5rem; max-width: 1020px; }
  .empty { text-align: center; color: var(--soft); }

  /* Masonry via CSS columns — no JS, handles wildly varying card heights, and
     cards never split across columns (break-inside: avoid, set on the card). */
  .masonry {
    column-width: 19rem;
    column-gap: 1.25rem;
  }
  .masonry > :global(.card) { margin: 0 0 1.25rem; }

  /* Above 1020px: stretch full-width and force a 4th column. Cards widen to
     fill the screen instead of the layout staying capped and centered. */
  @media (min-width: 1021px) {
    main { max-width: none; }
    .masonry { column-width: auto; column-count: 4; }
  }
</style>
