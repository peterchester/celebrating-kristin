---
import Base from '../layouts/Base.astro';
---

<Base title="Admin — Celebrating Kristin">
  <main class="wrap admin">
    <p class="back"><a href="/">← Home</a></p>
    <h1>Admin</h1>
    <p>
      Paste the admin token to enable <strong>Edit</strong> / <strong>Delete</strong>
      controls on every memory — on this device only. It's stored in your browser
      (an <code>rk_admin</code> cookie), never sent anywhere except with your own
      edit/delete requests, and you can clear it anytime.
    </p>

    <form id="admin-form">
      <label>
        Admin token
        <input name="token" type="password" autocomplete="off" placeholder="the RK_ADMIN_TOKEN the backend was started with" />
      </label>
      <div class="row">
        <button type="submit">Enable admin mode</button>
        <button type="button" id="clear" class="ghost">Clear</button>
      </div>
      <p id="state" role="status" aria-live="polite"></p>
    </form>

    <p class="note">
      The most durable way to administer is editing the JSON files in
      <code>src/content/entries/</code> and redeploying — see the README. This
      page is just the convenient path while the capture backend is running.
    </p>
  </main>
</Base>

<script>
  const form = document.getElementById('admin-form') as HTMLFormElement;
  const state = document.getElementById('state')!;
  const tokenInput = form.querySelector('[name="token"]') as HTMLInputElement;
  const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
  const secure = location.protocol === 'https:' ? '; secure' : '';

  // Same API-base derivation the memory page uses, so token checks hit the
  // capture backend (localhost:8787 in dev, the Function URL in prod).
  const SUBMIT = import.meta.env.PUBLIC_SUBMIT_API || '';
  const API_BASE =
    import.meta.env.PUBLIC_API_BASE ||
    (SUBMIT ? SUBMIT.replace(/\/submit$/, '') : (import.meta.env.DEV ? 'http://localhost:8787' : ''));

  const cookie = (k: string) => {
    const m = document.cookie.split('; ').find((c) => c.startsWith(k + '='));
    return m ? decodeURIComponent(m.slice(k.length + 1)) : null;
  };

  // The cookie never holds the raw token — only its SHA-256 hash. The backend
  // stores hash(ADMIN_TOKEN) and compares hashes, so the raw token is never sent
  // over the wire or persisted in the browser.
  async function sha256hex(text: string): Promise<string> {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(text));
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
  }
  const saveHash = (hash: string) => {
    document.cookie = `rk_admin=${encodeURIComponent(hash)}; path=/; max-age=${30 * 86400}; samesite=Lax${secure}`;
  };

  // Ask the backend whether a token HASH is THE admin token's hash.
  // true = valid, false = rejected (403), null = couldn't reach the backend.
  async function check(hash: string): Promise<boolean | null> {
    if (!API_BASE) return null;
    try {
      const r = await fetch(API_BASE + '/admin-check', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ adminToken: hash }),
      });
      if (r.ok) return true;
      if (r.status === 403) return false;
      return null;
    } catch { return null; }
  }

  // On load, report the REAL status of any saved token (not just "a cookie
  // exists"). The cookie already holds the hash, so check it directly.
  (async () => {
    const existing = cookie('rk_admin');
    if (!existing) { state.textContent = 'Admin mode is off.'; return; }
    const ok = await check(existing);
    state.textContent =
      ok === true ? 'Admin mode is ON on this device.'
      : ok === false ? 'The saved admin token is not valid — re-enter it below.'
      : 'Admin token saved (couldn’t reach the backend to verify it).';
  })();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const t = tokenInput.value.trim();
    if (!t) return;
    submitBtn.disabled = true;
    state.textContent = 'Checking…';
    const hash = await sha256hex(t);
    const ok = await check(hash);
    if (ok === false) {
      state.textContent = 'That token isn’t correct — nothing was saved.';
      submitBtn.disabled = false;
      return;
    }
    saveHash(hash);
    form.reset();
    state.textContent =
      ok === true
        ? 'Verified and saved. Open any memory to edit or delete it.'
        : 'Saved, but couldn’t reach the backend to verify it. Open a memory to test.';
    submitBtn.disabled = false;
  });

  document.getElementById('clear')!.addEventListener('click', () => {
    document.cookie = 'rk_admin=; path=/; max-age=0';
    state.textContent = 'Admin mode is off.';
  });
</script>

<style>
  .admin { padding-top: 2.5rem; max-width: 34rem; }
  .back { font-family: -apple-system, system-ui, sans-serif; font-size: .9rem; margin-bottom: 1.5rem; }
  h1 { font-weight: 400; font-size: 2.2rem; margin: 0 0 .5rem; }
  .admin > p { color: var(--soft); }
  form { display: grid; gap: 1rem; font-family: -apple-system, system-ui, sans-serif; margin: 1.5rem 0; }
  label { display: grid; gap: .4rem; font-size: .95rem; color: var(--ink); }
  input { font: inherit; padding: .6rem .7rem; border: 1px solid var(--line); border-radius: 8px; width: 100%; background: rgba(255, 255, 255, 0.05); color: var(--ink); }
  .row { display: flex; gap: .5rem; }
  button { padding: .6rem 1.2rem; border: 1px solid var(--accent); border-radius: 999px; background: var(--accent); color: #08111f; font: inherit; font-weight: 600; cursor: pointer; }
  button.ghost { background: transparent; color: var(--soft); border-color: var(--line); }
  #state { margin: 0; min-height: 1.1em; font-size: .9rem; }
  .note { color: var(--soft); font-size: .9rem; }
  code { background: rgba(255, 255, 255, 0.08); padding: .1em .35em; border-radius: 4px; }
</style>
