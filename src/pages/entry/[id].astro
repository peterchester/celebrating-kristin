---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Media from '../../components/Media.astro';

export async function getStaticPaths() {
  // Same order as the home gallery (newest first) so prev/next match what you see.
  const all = (await getCollection('entries'))
    .filter((e) => e.data.status !== 'hidden')
    .sort((a, b) => b.data.submittedAt.getTime() - a.data.submittedAt.getTime());
  return all.map((entry, i) => ({
    params: { id: entry.id },
    props: { entry, prevId: all[i - 1]?.id ?? null, nextId: all[i + 1]?.id ?? null },
  }));
}

const { entry, prevId, nextId } = Astro.props;
const { author, title, body, media, memoryDate } = entry.data;

// Blank lines separate paragraphs. Rendered via {p} so text is auto-escaped.
const paragraphs = body.split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean);
// submittedAt stays in the data (for gallery sorting) but is never shown. We only
// surface a date when the contributor gave one for the memory itself. Format in
// UTC so a date-only value doesn't slip to the previous day in the local zone.
const dateLabel = memoryDate
  ? memoryDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })
  : null;
const memoryDateInput = memoryDate ? memoryDate.toISOString().slice(0, 10) : '';

// Where edit/delete requests go. Empty in a plain static build → controls stay
// hidden and admin happens via the files (see README).
const API_BASE = import.meta.env.PUBLIC_API_BASE ?? (import.meta.env.DEV ? 'http://localhost:8787' : '');
---

<Base title={title ? `${title} — Celebrating Kristin` : `A memory from ${author.name}`}>
  <main class="wrap entry">
    {title && <h1>{title}</h1>}
    <p class="byline">
      <strong>{author.name}</strong>{author.relationship && <span> · {author.relationship}</span>}
      {dateLabel && <span class="date"> · {dateLabel}</span>}
    </p>

    {media[0] && (
      <Media type={media[0].type} src={media[0].src} poster={media[0].poster} caption={media[0].caption} alt={media[0].alt} />
    )}

    <article>
      {paragraphs.map((p) => <p>{p}</p>)}
    </article>

    {media.slice(1).map((m) => <Media type={m.type} src={m.src} poster={m.poster} caption={m.caption} alt={m.alt} />)}

    {/* Revealed by script only when this device owns the entry or admin mode is on. */}
    <section id="owner-tools" class="owner-tools" hidden>
      <div class="ot-bar">
        <span id="ot-label" class="ot-label"></span>
        <span class="ot-actions">
          <button type="button" id="ot-edit">Edit</button>
          <button type="button" id="ot-delete" class="danger">Delete</button>
        </span>
      </div>
      <form id="ot-form" hidden>
        <label>Title<input name="title" type="text" /></label>
        <label>Date of memory (optional)<input name="memoryDate" type="date" /></label>
        <label>Your name<input name="name" type="text" /></label>
        <label>How you knew Kristin<input name="relationship" type="text" /></label>
        <label>Your memory<textarea name="body" rows="10"></textarea></label>
        <div class="ot-buttons">
          <button type="submit">Save changes</button>
          <button type="button" id="ot-cancel" class="ghost">Cancel</button>
        </div>
        <p id="ot-status" role="status" aria-live="polite"></p>
      </form>
    </section>
  </main>

  <nav class="memory-nav" aria-label="Memory navigation">
    {prevId ? (
      <a class="nav-btn" href={`/entry/${prevId}`} rel="prev" aria-label="Previous memory">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 5l-7 7 7 7" /></svg>
      </a>
    ) : (
      <span class="nav-btn disabled" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 5l-7 7 7 7" /></svg>
      </span>
    )}

    <a class="nav-btn home" href="/" aria-label="All memories — home">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3.5 11.5 12 4l8.5 7.5" /><path d="M5.5 10v9.5h13V10" /></svg>
    </a>

    {nextId ? (
      <a class="nav-btn" href={`/entry/${nextId}`} rel="next" aria-label="Next memory">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5l7 7-7 7" /></svg>
      </a>
    ) : (
      <span class="nav-btn disabled" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5l7 7-7 7" /></svg>
      </span>
    )}
  </nav>

  <script define:vars={{ prevId, nextId }}>
    // Left/right arrow keys navigate, but never while typing in a field.
    document.addEventListener('keydown', (e) => {
      const t = e.target;
      if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      if (e.key === 'ArrowLeft' && prevId) location.href = '/entry/' + prevId;
      if (e.key === 'ArrowRight' && nextId) location.href = '/entry/' + nextId;
    });
  </script>

  <script define:vars={{ id: entry.id, API_BASE, d: { title: title ?? '', body, name: author.name, rel: author.relationship ?? '', memoryDate: memoryDateInput } }}>
    (function () {
      if (!API_BASE) return; // static build with no backend → file-based admin only

      const cookie = (k) => {
        const m = document.cookie.split('; ').find((c) => c.startsWith(k + '='));
        return m ? decodeURIComponent(m.slice(k.length + 1)) : null;
      };

      let ownerToken = null;
      try {
        const list = JSON.parse(cookie('rk_owner') || '[]');
        ownerToken = (list.find((e) => e.id === id) || {}).token || null;
      } catch {}
      const adminToken = cookie('rk_admin');
      if (!ownerToken && !adminToken) return; // not the owner, not admin → leave hidden

      const tools = document.getElementById('owner-tools');
      const form = document.getElementById('ot-form');
      const statusEl = document.getElementById('ot-status');
      const fld = (n) => form.querySelector('[name="' + n + '"]');

      document.getElementById('ot-label').textContent = ownerToken
        ? 'This is your memory — you can edit or remove it.'
        : 'Admin controls.';
      fld('title').value = d.title;
      fld('memoryDate').value = d.memoryDate;
      fld('memoryDate').max = new Date().toISOString().slice(0, 10); // no future dates
      fld('name').value = d.name;
      fld('relationship').value = d.rel;
      fld('body').value = d.body;
      tools.hidden = false;

      const creds = () => (ownerToken ? { token: ownerToken } : { adminToken });
      const post = (path, extra) =>
        fetch(API_BASE + path, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ id, ...creds(), ...extra }),
        });

      document.getElementById('ot-edit').addEventListener('click', () => { form.hidden = !form.hidden; });
      document.getElementById('ot-cancel').addEventListener('click', () => { form.hidden = true; });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        statusEl.textContent = 'Saving…';
        try {
          const r = await post('/update', {
            title: fld('title').value,
            memoryDate: fld('memoryDate').value,
            name: fld('name').value,
            relationship: fld('relationship').value,
            body: fld('body').value,
          });
          if (!r.ok) throw new Error('Could not save — your edit access may have expired.');
          location.reload();
        } catch (err) { statusEl.textContent = err.message; }
      });

      document.getElementById('ot-delete').addEventListener('click', async () => {
        if (!confirm('Permanently delete this memory? This cannot be undone.')) return;
        try {
          const r = await post('/delete', {});
          if (!r.ok) throw new Error('Could not delete — your access may have expired.');
          // Forget this entry's token in the owner cookie.
          try {
            const list = JSON.parse(cookie('rk_owner') || '[]').filter((e) => e.id !== id);
            const secure = location.protocol === 'https:' ? '; secure' : '';
            document.cookie = 'rk_owner=' + encodeURIComponent(JSON.stringify(list)) + '; path=/; max-age=' + 90 * 86400 + '; samesite=Lax' + secure;
          } catch {}
          location.href = '/';
        } catch (err) { alert(err.message); }
      });
    })();
  </script>
</Base>

<style>
  .entry { padding-top: 2.5rem; }
  .entry h1 { font-weight: 400; font-size: 2.2rem; margin: 0 0 .4rem; }
  .byline { color: var(--soft); font-family: -apple-system, system-ui, sans-serif; font-size: .95rem; margin: 0 0 2rem; }
  .byline strong { color: var(--ink); font-weight: 600; }
  article p { margin: 0 0 1.3rem; }

  .owner-tools { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px dashed var(--line); font-family: -apple-system, system-ui, sans-serif; }
  .ot-bar { display: flex; flex-wrap: wrap; gap: .75rem; align-items: center; justify-content: space-between; }
  .ot-label { color: var(--soft); font-size: .9rem; }
  .ot-actions { display: flex; gap: .5rem; }
  .owner-tools button {
    padding: .45rem 1rem; border: 1px solid var(--line); border-radius: 999px;
    background: rgba(255, 255, 255, 0.06); color: var(--ink); font: inherit; font-size: .9rem; cursor: pointer;
  }
  .owner-tools button.danger { color: #ff9a8a; border-color: rgba(255, 120, 100, 0.35); }
  .owner-tools button.ghost { color: var(--soft); }
  #ot-form { display: grid; gap: 1rem; margin-top: 1.5rem; }
  #ot-form label { display: grid; gap: .35rem; font-size: .9rem; }
  #ot-form input, #ot-form textarea { font: inherit; padding: .6rem .7rem; border: 1px solid var(--line); border-radius: 8px; width: 100%; background: rgba(255, 255, 255, 0.05); color: var(--ink); }
  #ot-form textarea { font-family: Georgia, serif; line-height: 1.6; resize: vertical; }
  .ot-buttons { display: flex; gap: .5rem; }
  .ot-buttons button[type="submit"] { background: var(--accent); color: #08111f; border-color: var(--accent); font-weight: 600; }
  #ot-status { margin: 0; min-height: 1.1em; color: var(--soft); font-size: .9rem; }

  /* Floating prev / home / next bar. 46px hit targets, safe-area aware, blurred. */
  .memory-nav {
    position: fixed;
    left: 50%;
    transform: translateX(-50%);
    bottom: calc(1.25rem + env(safe-area-inset-bottom, 0px));
    z-index: 30;
    display: flex;
    align-items: center;
    gap: 0.15rem;
    padding: 0.3rem;
    background: rgba(14, 18, 38, 0.72);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--line);
    border-radius: 999px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.45), 0 0 22px var(--glow);
  }
  .nav-btn {
    -webkit-tap-highlight-color: transparent;
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    color: var(--ink);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .nav-btn svg { width: 22px; height: 22px; display: block; }
  .nav-btn.home svg { width: 23px; height: 23px; }
  .nav-btn:hover { background: rgba(255, 255, 255, 0.08); color: var(--accent); }
  .nav-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .nav-btn.disabled { color: rgba(154, 166, 201, 0.35); pointer-events: none; }

  /* Keep the floating bar from covering the page footer. */
  :global(footer.site) { margin-bottom: 5rem; }
</style>
