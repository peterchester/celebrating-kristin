---
import Base from '../../layouts/Base.astro';
// Single-post viewer. CloudFront routes every /memory/<slug> request to this one
// page; the script reads the slug from the URL, fetches /entries/<slug>.json, and
// renders it in the browser — so new memories work with no rebuild. Markup +
// styles for the body come from src/lib/render.ts + styles/content.css.

// Cloudflare Turnstile site key for the reflection form (same default as the share form).
const TURNSTILE_SITE_KEY =
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? (import.meta.env.DEV ? '1x00000000000000000000AA' : '');
---

<Base>
  <div id="thanks-toast" class="thanks-toast" role="status">Thank you for sharing this memory. 🤍</div>
  <div id="post-banner"></div>

  <main class="wrap entry">
    <div id="post-content"></div>
    <p id="not-found" hidden>That memory couldn’t be found. <a href="/">Back to all memories</a></p>

    {/* Revealed by script only when this device owns the entry or admin mode is on. */}
    <section id="owner-tools" class="owner-tools" hidden>
      <div class="ot-bar">
        <span id="ot-label" class="ot-label"></span>
        <span class="ot-actions">
          <button type="button" id="ot-edit">Edit</button>
          <button type="button" id="ot-delete" class="danger">Delete</button>
        </span>
      </div>
      <form id="ot-form" hidden>
        <label>Title<input name="title" type="text" /></label>
        <label>Date of memory (optional)<input name="memoryDate" type="date" /></label>
        <label>Your name<input name="name" type="text" /></label>
        <label>How you knew Kristin<input name="relationship" type="text" /></label>
        <label>Your memory<textarea name="body" rows="10"></textarea></label>
        <div class="ot-buttons">
          <button type="submit">Save changes</button>
          <button type="button" id="ot-cancel" class="ghost">Cancel</button>
        </div>
        <p id="ot-status" role="status" aria-live="polite"></p>
      </form>
    </section>

    <section id="reflections" class="reflections" hidden>
      <h2 class="reflections-title">Reflections</h2>
      <div id="reflections-list" class="reflections-list"></div>
      <form id="reflection-form" class="reflection-form">
        <p class="rf-lede">Add your own perspective to this memory. Share your experience, your thoughts, your photos, or your recording.</p>
        <label>
          <span>Your name <span class="req">*</span></span>
          <input name="name" type="text" required autocomplete="name" />
        </label>
        <label>
          How did you know Kristin?
          <input name="relationship" type="text" placeholder="Friend, cousin, coworker…" />
        </label>
        <label>
          Your reflection
          <textarea name="body" rows="4" placeholder="Share a memory or a few words…"></textarea>
        </label>
        <label>
          Add a photo, audio, or video
          <input name="media" type="file" multiple accept="image/*,audio/*,video/*" />
        </label>
        {TURNSTILE_SITE_KEY && <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="dark"></div>}
        <button type="submit">Add reflection</button>
        <p id="rf-status" role="status" aria-live="polite"></p>
      </form>
    </section>
  </main>

  <nav class="memory-nav" aria-label="Memory navigation" hidden>
    <a class="nav-btn disabled" id="nav-prev" rel="prev" href="#" aria-label="Previous memory">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 5l-7 7 7 7" /></svg>
    </a>
    <a class="nav-btn home" href="/" aria-label="All memories — home">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3.5 11.5 12 4l8.5 7.5" /><path d="M5.5 10v9.5h13V10" /></svg>
    </a>
    <a class="nav-btn disabled" id="nav-next" rel="next" href="#" aria-label="Next memory">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5l7 7-7 7" /></svg>
    </a>
  </nav>
  {TURNSTILE_SITE_KEY && <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}
</Base>

<script>
  import { bannerHTML, postContentHTML, reflectionHTML } from '../../lib/render';

  // Edit/delete go to the Lambda. Reads (entry + index) are same-origin static
  // JSON. API base: explicit PUBLIC_API_BASE, else derived from PUBLIC_SUBMIT_API.
  const SUBMIT = import.meta.env.PUBLIC_SUBMIT_API || '';
  const API_BASE =
    import.meta.env.PUBLIC_API_BASE ||
    (SUBMIT ? SUBMIT.replace(/\/submit$/, '') : (import.meta.env.DEV ? 'http://localhost:8787' : ''));
  const PRESIGN = import.meta.env.PUBLIC_PRESIGN_API || (API_BASE ? API_BASE + '/presign' : '');
  const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || (import.meta.env.DEV ? '1x00000000000000000000AA' : '');

  const match = location.pathname.match(/^\/memory\/([^/]+)\/?$/);
  const id = match ? decodeURIComponent(match[1]) : '';

  const bannerEl = document.getElementById('post-banner');
  const contentEl = document.getElementById('post-content');
  const notFound = document.getElementById('not-found');
  const navEl = document.querySelector('.memory-nav') as HTMLElement | null;

  const cookie = (k: string) => {
    const m = document.cookie.split('; ').find((c) => c.startsWith(k + '='));
    return m ? decodeURIComponent(m.slice(k.length + 1)) : null;
  };

  function showNotFound() {
    if (notFound) notFound.hidden = false;
    if (navEl) navEl.hidden = false;
  }

  async function setupNav(currentId: string) {
    let prev: string | null = null;
    let next: string | null = null;
    try {
      const r = await fetch('/data/index.json', { cache: 'no-store' });
      if (r.ok) {
        const list = await r.json();
        list.sort((a: any, b: any) => String(b.submittedAt || '').localeCompare(String(a.submittedAt || '')));
        const i = list.findIndex((e: any) => e.id === currentId);
        if (i !== -1) { prev = list[i - 1]?.id ?? null; next = list[i + 1]?.id ?? null; }
      }
    } catch {}
    const prevA = document.getElementById('nav-prev') as HTMLAnchorElement | null;
    const nextA = document.getElementById('nav-next') as HTMLAnchorElement | null;
    if (prev && prevA) { prevA.href = '/memory/' + prev; prevA.classList.remove('disabled'); }
    if (next && nextA) { nextA.href = '/memory/' + next; nextA.classList.remove('disabled'); }
    if (navEl) navEl.hidden = false;

    document.addEventListener('keydown', (e) => {
      const t = e.target as HTMLElement | null;
      if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      if (e.key === 'ArrowLeft' && prev) location.href = '/memory/' + prev;
      if (e.key === 'ArrowRight' && next) location.href = '/memory/' + next;
    });
  }

  function setupTools(entry: any) {
    if (!API_BASE) return; // no backend → file-based admin only

    let ownerToken: string | null = null;
    try {
      const list = JSON.parse(cookie('rk_owner') || '[]');
      ownerToken = (list.find((e: any) => e.id === id) || {}).token || null;
    } catch {}
    const adminToken = cookie('rk_admin');
    if (!ownerToken && !adminToken) return; // not owner, not admin → leave hidden

    const tools = document.getElementById('owner-tools') as HTMLElement;
    const form = document.getElementById('ot-form') as HTMLFormElement;
    const statusEl = document.getElementById('ot-status') as HTMLElement;
    const fld = (n: string) => form.querySelector('[name="' + n + '"]') as HTMLInputElement;

    (document.getElementById('ot-label') as HTMLElement).textContent = ownerToken
      ? 'This is your memory — you can edit or remove it.'
      : 'Admin controls.';
    fld('title').value = entry.title || '';
    fld('memoryDate').value = entry.memoryDate || '';
    fld('memoryDate').max = new Date().toISOString().slice(0, 10);
    fld('name').value = entry.author?.name || '';
    fld('relationship').value = entry.author?.relationship || '';
    fld('body').value = entry.body || '';
    tools.hidden = false;

    const creds = () => (ownerToken ? { token: ownerToken } : { adminToken });
    const post = (path: string, extra: any) =>
      fetch(API_BASE + path, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ id, ...creds(), ...extra }),
      });

    document.getElementById('ot-edit')!.addEventListener('click', () => { form.hidden = !form.hidden; });
    document.getElementById('ot-cancel')!.addEventListener('click', () => { form.hidden = true; });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      statusEl.textContent = 'Saving…';
      try {
        const r = await post('/update', {
          title: fld('title').value,
          memoryDate: fld('memoryDate').value,
          name: fld('name').value,
          relationship: fld('relationship').value,
          body: fld('body').value,
        });
        if (!r.ok) throw new Error('Could not save — your edit access may have expired.');
        location.reload();
      } catch (err) { statusEl.textContent = (err as Error).message; }
    });

    document.getElementById('ot-delete')!.addEventListener('click', async () => {
      if (!confirm('Permanently delete this memory? This cannot be undone.')) return;
      try {
        const r = await post('/delete', {});
        if (!r.ok) throw new Error('Could not delete — your access may have expired.');
        try {
          const list = JSON.parse(cookie('rk_owner') || '[]').filter((e: any) => e.id !== id);
          const secure = location.protocol === 'https:' ? '; secure' : '';
          document.cookie = 'rk_owner=' + encodeURIComponent(JSON.stringify(list)) + '; path=/; max-age=' + 90 * 86400 + '; samesite=Lax' + secure;
        } catch {}
        location.href = '/';
      } catch (err) { alert((err as Error).message); }
    });
  }

  // ── Reflections (contributions others add to this memory) ──────────────────
  function rememberOwner(oid: string, token: string) {
    let list: any[] = [];
    try { list = JSON.parse(cookie('rk_owner') || '[]'); } catch {}
    list.push({ id: oid, token });
    const secure = location.protocol === 'https:' ? '; secure' : '';
    document.cookie = 'rk_owner=' + encodeURIComponent(JSON.stringify(list)) + '; path=/; max-age=' + 90 * 86400 + '; samesite=Lax' + secure;
  }
  function forgetOwner(oid: string) {
    try {
      const list = JSON.parse(cookie('rk_owner') || '[]').filter((e: any) => e.id !== oid);
      const secure = location.protocol === 'https:' ? '; secure' : '';
      document.cookie = 'rk_owner=' + encodeURIComponent(JSON.stringify(list)) + '; path=/; max-age=' + 90 * 86400 + '; samesite=Lax' + secure;
    } catch {}
  }
  function loadProfileInto(form: HTMLFormElement) {
    try {
      const c = cookie('rk_profile'); if (!c) return;
      const p = JSON.parse(c);
      const set = (n: string, v?: string) => { const el = form.querySelector('[name="' + n + '"]') as HTMLInputElement | null; if (el && v) el.value = v; };
      set('name', p.name); set('relationship', p.relationship);
    } catch {}
  }
  function saveProfileFrom(form: HTMLFormElement) {
    const fd = new FormData(form);
    let prev: any = {}; try { prev = JSON.parse(cookie('rk_profile') || '{}'); } catch {}
    const p = { ...prev, name: String(fd.get('name') || '').trim(), relationship: String(fd.get('relationship') || '').trim() };
    const secure = location.protocol === 'https:' ? '; secure' : '';
    document.cookie = 'rk_profile=' + encodeURIComponent(JSON.stringify(p)) + '; path=/; max-age=' + 365 * 86400 + '; samesite=Lax' + secure;
  }
  async function uploadReflectionFile(file: File) {
    const res = await fetch(PRESIGN, { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ filename: file.name, contentType: file.type, size: file.size }) });
    if (!res.ok) throw new Error('Could not get upload URL');
    const { url, key } = await res.json();
    const put = await fetch(url, { method: 'PUT', headers: { 'content-type': file.type }, body: file });
    if (!put.ok) throw new Error('Upload failed for ' + file.name);
    const kind = file.type.startsWith('image/') ? 'image' : file.type.startsWith('audio/') ? 'audio' : 'video';
    return { type: kind, src: key, caption: '' };
  }

  async function setupReflections() {
    const section = document.getElementById('reflections') as HTMLElement | null;
    const listEl = document.getElementById('reflections-list') as HTMLElement | null;
    const form = document.getElementById('reflection-form') as HTMLFormElement | null;
    const statusEl = document.getElementById('rf-status') as HTMLElement | null;
    if (!section || !listEl || !form || !statusEl) return;
    section.hidden = false;

    const adminToken = cookie('rk_admin');
    const owned = () => { try { return JSON.parse(cookie('rk_owner') || '[]'); } catch { return []; } };
    let items: any[] = []; // local source of truth so new reflections show instantly

    // Render from the local list — never re-fetch right after a write, since a
    // just-written comments file is stale behind CloudFront (and briefly the dev
    // server) for a moment.
    function draw() {
      listEl!.innerHTML = items.map(reflectionHTML).join('');
      const mine = owned();
      listEl!.querySelectorAll('.reflection').forEach((el) => {
        const cid = el.getAttribute('data-id') || '';
        const own = mine.find((o: any) => o.id === 'comment:' + cid);
        if (adminToken || own) {
          const btn = el.querySelector('.reflection-del') as HTMLButtonElement | null;
          if (btn) { btn.hidden = false; btn.addEventListener('click', () => deleteReflection(cid, own ? own.token : null)); }
        }
      });
    }

    async function deleteReflection(cid: string, token: string | null) {
      if (!confirm('Delete this reflection?')) return;
      try {
        const r = await fetch(API_BASE + '/comment-delete', {
          method: 'POST', headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ entryId: id, commentId: cid, token: token || undefined, adminToken: adminToken || undefined }),
        });
        if (!r.ok) throw new Error('Could not delete.');
        if (token) forgetOwner('comment:' + cid);
        items = items.filter((c) => c.id !== cid);
        draw();
      } catch (e) { alert((e as Error).message); }
    }

    loadProfileInto(form);

    // Keep name / relationship sticky the moment they change (shared with the
    // share form via the rk_profile cookie).
    ['name', 'relationship'].forEach((n) => {
      form!.querySelector(`[name="${n}"]`)?.addEventListener('change', () => saveProfileFrom(form!));
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      statusEl!.textContent = 'Sending…';
      try {
        if (!API_BASE) throw new Error('Reflections aren’t connected yet.');
        const fd = new FormData(form);
        const turnstileToken = String(fd.get('cf-turnstile-response') || '');
        if (TURNSTILE_SITE_KEY && !turnstileToken) { statusEl!.textContent = 'Please complete the “I’m not a robot” check.'; btn.disabled = false; return; }
        const bodyText = String(fd.get('body') || '').trim();
        const files = (form.querySelector('input[name="media"]') as HTMLInputElement).files;
        if (!bodyText && !(files && files.length)) { statusEl!.textContent = 'Please write something, or add a photo, video, or audio.'; btn.disabled = false; return; }
        const media: any[] = [];
        if (files && files.length && PRESIGN) {
          for (const file of Array.from(files)) { statusEl!.textContent = 'Uploading ' + file.name + '…'; media.push(await uploadReflectionFile(file)); }
        }
        const payload = {
          entryId: id,
          author: { name: String(fd.get('name') || '').trim(), relationship: String(fd.get('relationship') || '').trim() || undefined },
          body: bodyText || undefined,
          media,
          turnstileToken: turnstileToken || undefined,
        };
        const r = await fetch(API_BASE + '/comment', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(payload) });
        if (!r.ok) throw new Error('Could not post your reflection.');
        const { id: cid, editToken } = await r.json();
        if (cid && editToken) rememberOwner('comment:' + cid, editToken);
        saveProfileFrom(form);
        // Show it immediately from what we just submitted (a re-fetch would be stale).
        items.push({ id: cid, author: payload.author, body: payload.body, media: payload.media, createdAt: new Date().toISOString() });
        draw();
        (form.querySelector('textarea[name="body"]') as HTMLTextAreaElement).value = '';
        (form.querySelector('input[name="media"]') as HTMLInputElement).value = '';
        statusEl!.textContent = 'Thank you for adding your reflection. 🤍';
      } catch (err) {
        statusEl!.textContent = (err as Error).message;
      } finally {
        btn.disabled = false;
        if ((window as any).turnstile) (window as any).turnstile.reset();
      }
    });

    // Initial load (fetched once on page open).
    try { const r = await fetch('/comments/' + encodeURIComponent(id) + '.json', { cache: 'no-store' }); if (r.ok) items = await r.json(); } catch {}
    draw();
  }

  // A just-submitted memory can take a beat to become readable (CloudFront/S3
  // propagation in production, or the dev file write locally). Retry briefly
  // before giving up, so the post-submit redirect doesn't land on "not found".
  async function fetchEntry(entryId: string) {
    for (let i = 0; i < 4; i++) {
      try {
        const r = await fetch('/entries/' + encodeURIComponent(entryId) + '.json', { cache: 'no-store' });
        if (r.ok) return await r.json();
      } catch {}
      if (i < 3) await new Promise((res) => setTimeout(res, 350 + i * 300));
    }
    return null;
  }

  async function main() {
    if (!id) return showNotFound();
    const entry = await fetchEntry(id);
    if (!entry) return showNotFound();

    document.title = (entry.title ? entry.title : 'A memory from ' + (entry.author?.name || 'a friend')) + ' — Celebrating Kristin';
    if (bannerEl) bannerEl.innerHTML = bannerHTML(entry);
    if (contentEl) contentEl.innerHTML = postContentHTML(entry);

    setupNav(id);
    setupTools(entry);
    setupReflections();
  }

  // Just arrived from a successful submission → show a fading thank-you.
  function showThanks() {
    const t = document.getElementById('thanks-toast');
    if (!t) return;
    requestAnimationFrame(() => t.classList.add('show'));
    setTimeout(() => t.classList.remove('show'), 4500);
  }
  try {
    if (sessionStorage.getItem('rk_justShared')) {
      sessionStorage.removeItem('rk_justShared');
      showThanks();
    }
  } catch {}

  main();
</script>

<style>
  .owner-tools { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px dashed var(--line); font-family: -apple-system, system-ui, sans-serif; }
  .ot-bar { display: flex; flex-wrap: wrap; gap: .75rem; align-items: center; justify-content: space-between; }
  .ot-label { color: var(--soft); font-size: .9rem; }
  .ot-actions { display: flex; gap: .5rem; }
  .owner-tools button {
    padding: .45rem 1rem; border: 1px solid var(--line); border-radius: 999px;
    background: rgba(255, 255, 255, 0.06); color: var(--ink); font: inherit; font-size: .9rem; cursor: pointer;
  }
  .owner-tools button.danger { color: #ff9a8a; border-color: rgba(255, 120, 100, 0.35); }
  .owner-tools button.ghost { color: var(--soft); }
  #ot-form { display: grid; gap: 1rem; margin-top: 1.5rem; }
  /* #ot-form (an id) outranks the UA [hidden] rule, so hidden was ignored.
     This restores it: the form stays hidden until the Edit button toggles it. */
  #ot-form[hidden] { display: none; }
  #ot-form label { display: grid; gap: .35rem; font-size: .9rem; }
  #ot-form input, #ot-form textarea { font: inherit; padding: .6rem .7rem; border: 1px solid var(--line); border-radius: 8px; width: 100%; background: rgba(255, 255, 255, 0.05); color: var(--ink); }
  #ot-form textarea { font-family: Georgia, serif; line-height: 1.6; resize: vertical; }
  .ot-buttons { display: flex; gap: .5rem; }
  .ot-buttons button[type="submit"] { background: var(--accent); color: #08111f; border-color: var(--accent); font-weight: 600; }
  #ot-status { margin: 0; min-height: 1.1em; color: var(--soft); font-size: .9rem; }
  #not-found { color: var(--soft); }

  /* Floating prev / home / next bar. 46px hit targets, safe-area aware, blurred. */
  .memory-nav {
    position: fixed; left: 50%; transform: translateX(-50%);
    bottom: calc(1.25rem + env(safe-area-inset-bottom, 0px));
    z-index: 30; display: flex; align-items: center; gap: 0.15rem; padding: 0.3rem;
    background: rgba(14, 18, 38, 0.72);
    -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px);
    border: 1px solid var(--line); border-radius: 999px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.45), 0 0 22px var(--glow);
  }
  .nav-btn {
    -webkit-tap-highlight-color: transparent;
    display: grid; place-items: center; width: 46px; height: 46px; border-radius: 50%;
    color: var(--ink); text-decoration: none; transition: background 0.15s ease, color 0.15s ease;
  }
  .nav-btn svg { width: 22px; height: 22px; display: block; }
  .nav-btn.home svg { width: 23px; height: 23px; }
  .nav-btn:hover { background: rgba(255, 255, 255, 0.08); color: var(--accent); }
  .nav-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .nav-btn.disabled { color: rgba(154, 166, 201, 0.35); pointer-events: none; }


  /* Fading thank-you shown after a successful submission. */
  .thanks-toast {
    position: fixed; top: calc(1rem + env(safe-area-inset-top, 0px)); left: 50%;
    transform: translateX(-50%) translateY(-8px);
    z-index: 50; max-width: min(92vw, 30rem); text-align: center;
    padding: .7rem 1.2rem; border-radius: 999px;
    background: rgba(14, 18, 38, 0.82);
    -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px);
    border: 1px solid var(--line); color: var(--ink);
    font-family: -apple-system, system-ui, sans-serif; font-size: .95rem;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.45), 0 0 22px var(--glow);
    opacity: 0; pointer-events: none;
    transition: opacity .5s ease, transform .5s ease;
  }
  .thanks-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    .thanks-toast, .thanks-toast.show { transition: opacity .5s ease; transform: translateX(-50%); }
  }

  /* Reflections */
  .reflections { margin-top: 3.5rem; padding-top: 2rem; border-top: 1px solid var(--line); font-family: -apple-system, system-ui, sans-serif; }
  .reflections-title { font-family: 'Vujahday Script', cursive; font-weight: 400; font-size: 2.6rem; line-height: 1; margin: 0 0 1.25rem; }
  .reflection { border-top: 1px solid var(--line); padding: 1.25rem 0; }
  .reflections-list .reflection:first-child { border-top: none; padding-top: 0; }
  .reflection .byline { color: var(--soft); font-size: .9rem; margin: 0 0 .5rem; }
  .reflection-body { font-family: Georgia, serif; }
  .reflection-body p { margin: 0 0 .8rem; }
  .reflection-del { margin-top: .5rem; padding: .3rem .8rem; border: 1px solid rgba(255, 120, 100, .35); border-radius: 999px; background: rgba(255, 255, 255, .05); color: #ff9a8a; font: inherit; font-size: .8rem; cursor: pointer; }
  .reflection-del[hidden] { display: none; }

  .reflection-form { margin-top: 2.5rem; display: grid; gap: 1rem; }
  .reflection-form .rf-lede { color: var(--soft); margin: 0; }
  .reflection-form label { display: grid; gap: .35rem; font-size: .9rem; }
