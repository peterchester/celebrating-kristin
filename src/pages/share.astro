---
import Base from '../layouts/Base.astro';

// Cloudflare Turnstile site key (public, safe to ship). Defaults to Cloudflare's
// "always passes" TEST key in dev so the check works out of the box; set
// PUBLIC_TURNSTILE_SITE_KEY to your real key for production. Empty = no check.
const TURNSTILE_SITE_KEY =
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? (import.meta.env.DEV ? '1x00000000000000000000AA' : '');
---

<Base title="Share a memory — Celebrating Kristin">
  <main class="wrap form-page">
    <p class="back"><a href="/">← All memories</a></p>
    <h1>Share a memory</h1>
    <p class="lede">
      A story, a moment, something she said. As long or as short as you like.
      You can add photos, a voice recording, or a video too.
    </p>

    <form id="memory-form">
      <label>
        Your name <span class="req">*</span>
        <input name="name" type="text" required autocomplete="name" />
      </label>

      <label>
        How did you know Kristin?
        <input name="relationship" type="text" placeholder="Friend, cousin, coworker…" />
      </label>

      <label>
        Title (optional)
        <input name="title" type="text" placeholder="Give your memory a name" />
      </label>

      <label>
        Date of memory (optional)
        <input name="memoryDate" type="date" />
        <small>When did this happen? Leave blank if it's not tied to a day.</small>
      </label>

      <label>
        Your memory <span class="req">*</span>
        <textarea name="body" rows="10" required placeholder="Take your time…"></textarea>
      </label>

      <label>
        Add photos, audio, or video (optional)
        <input name="media" type="file" multiple accept="image/*,audio/*,video/*" />
        <small>Large videos are fine — they upload directly and securely.</small>
      </label>

      <label class="email">
        Your email (optional, never shown publicly)
        <input name="email" type="email" autocomplete="email" placeholder="So we can reach you if needed" />
      </label>

      {TURNSTILE_SITE_KEY && <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="dark"></div>}

      <button type="submit">Share this memory</button>
      <p id="status" role="status" aria-live="polite"></p>
    </form>
  </main>
  {TURNSTILE_SITE_KEY && <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}
</Base>

<script>
  // ── Capture backend ────────────────────────────────────────────────────────
  // Point these at your serverless endpoints when Phase 1 is wired up.
  //   PRESIGN_API → returns { url, key } for a direct-to-S3 upload
  //   SUBMIT_API  → accepts the submission JSON, saves one entry file
  // In `npm run dev` these default to the local mock backend
  // (capture/dev-server.mjs) so you can test the full loop without AWS.
  // In a production build they're empty unless you set PUBLIC_PRESIGN_API /
  // PUBLIC_SUBMIT_API — and while empty the form runs in "preview" mode,
  // logging the exact JSON it WOULD send so you can see the data model.
  const DEV = import.meta.env.DEV;
  const PRESIGN_API = import.meta.env.PUBLIC_PRESIGN_API ?? (DEV ? 'http://localhost:8787/presign' : '');
  const SUBMIT_API = import.meta.env.PUBLIC_SUBMIT_API ?? (DEV ? 'http://localhost:8787/submit' : '');
  const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? (DEV ? '1x00000000000000000000AA' : '');

  const form = document.getElementById('memory-form') as HTMLFormElement;
  const statusEl = document.getElementById('status') as HTMLParagraphElement;

  // Memory dates can be any time in the past, but not the future. Cap the picker
  // at today (set at load so it's correct regardless of when the site was built).
  const memoryDateInput = form.querySelector('input[name="memoryDate"]') as HTMLInputElement;
  if (memoryDateInput) memoryDateInput.max = new Date().toISOString().slice(0, 10);

  function setStatus(msg: string, kind: 'ok' | 'err' | '' = '') {
    statusEl.textContent = msg;
    statusEl.className = kind;
  }

  // Persist this entry's edit token so the contributor can edit/delete it later.
  // When this cookie expires (~90 days) or is cleared, they simply lose access.
  function rememberOwner(id: string, token: string) {
    let list: { id: string; token: string }[] = [];
    try {
      const c = document.cookie.split('; ').find((x) => x.startsWith('rk_owner='));
      if (c) list = JSON.parse(decodeURIComponent(c.slice('rk_owner='.length)));
    } catch {}
    list.push({ id, token });
    const secure = location.protocol === 'https:' ? '; secure' : '';
    document.cookie = `rk_owner=${encodeURIComponent(JSON.stringify(list))}; path=/; max-age=${90 * 86400}; samesite=Lax${secure}`;
  }

  async function uploadFile(file: File) {
    // Ask the backend for a presigned URL, then PUT the bytes straight to storage.
    const res = await fetch(PRESIGN_API, {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ filename: file.name, contentType: file.type, size: file.size }),
    });
    if (!res.ok) throw new Error('Could not get upload URL');
    const { url, key } = await res.json();
    const put = await fetch(url, { method: 'PUT', headers: { 'content-type': file.type }, body: file });
    if (!put.ok) throw new Error(`Upload failed for ${file.name}`);
    const kind = file.type.startsWith('image/') ? 'image' : file.type.startsWith('audio/') ? 'audio' : 'video';
    return { type: kind, src: key, caption: '' };
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button')!;
    btn.disabled = true;
    setStatus('Sending…');

    try {
      const fd = new FormData(form);

      // Require the "not a robot" check (if enabled) before uploading anything.
      const turnstileToken = String(fd.get('cf-turnstile-response') || '');
      if (TURNSTILE_SITE_KEY && !turnstileToken) {
        setStatus('Please complete the “I’m not a robot” check.', 'err');
        btn.disabled = false;
        return;
      }

      const files = (form.querySelector('input[name="media"]') as HTMLInputElement).files;

      const media = [];
      if (files && files.length && PRESIGN_API) {
        for (const file of Array.from(files)) {
          setStatus(`Uploading ${file.name}…`);
          media.push(await uploadFile(file));
        }
      }

      // The submission object — mirrors docs/DATA-MODEL.md (the backend assigns
      // the id/filename and submittedAt; email is kept private, not in the entry).
      const submission = {
        author: {
          name: String(fd.get('name') || '').trim(),
          relationship: String(fd.get('relationship') || '').trim() || undefined,
        },
        title: String(fd.get('title') || '').trim() || undefined,
        memoryDate: String(fd.get('memoryDate') || '') || undefined, // validated server-side
        body: String(fd.get('body') || '').trim(),
        media,
        email: String(fd.get('email') || '').trim() || undefined, // private — backend stores separately
        turnstileToken: turnstileToken || undefined, // verified server-side, never stored
      };

      if (!SUBMIT_API) {
        console.log('[preview] would submit:', submission);
        setStatus('Preview mode: backend not connected yet. Your submission was logged to the console.', 'ok');
        btn.disabled = false;
        return;
      }

      const res = await fetch(SUBMIT_API, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(submission),
      });
      if (!res.ok) throw new Error('Submission failed');
      const { id, editToken } = await res.json();
      if (id && editToken) rememberOwner(id, editToken);

      form.reset();
      setStatus('Thank you. Your memory has been shared. 🤍 You can edit or remove it from its page on this device.', 'ok');
    } catch (err) {
      setStatus((err as Error).message || 'Something went wrong. Please try again.', 'err');
    } finally {
      btn.disabled = false;
      // Turnstile tokens are single-use — reset so the widget is ready to retry.
      if ((window as any).turnstile) (window as any).turnstile.reset();
    }
  });
</script>

<style>
  .form-page { padding-top: 2.5rem; max-width: 38rem; }
  .back { font-family: -apple-system, system-ui, sans-serif; font-size: .9rem; margin-bottom: 1.5rem; }
  h1 { font-weight: 400; font-size: 2.2rem; margin: 0 0 .5rem; }
  .lede { color: var(--soft); margin: 0 0 2rem; }
  form { display: grid; gap: 1.4rem; font-family: -apple-system, system-ui, sans-serif; }
  label { display: grid; gap: .4rem; font-size: .95rem; }
  .req { color: #ff9a8a; }
  input, textarea {
    font: inherit; padding: .7rem .8rem; border: 1px solid var(--line); border-radius: 8px;
    background: rgba(255, 255, 255, 0.05); color: var(--ink); width: 100%;
  }
  input::placeholder, textarea::placeholder { color: rgba(154, 166, 201, 0.6); }
  textarea { font-family: Georgia, serif; line-height: 1.6; resize: vertical; }
  input:focus, textarea:focus { outline: 2px solid var(--accent); outline-offset: 1px; border-color: transparent; }
  small { color: var(--soft); }
  button {
    justify-self: start; padding: .8rem 1.6rem; border: none; border-radius: 999px;
    background: linear-gradient(120deg, #7ee8c9, #8fd0f0); color: #08111f; font: inherit;
    font-size: 1rem; font-weight: 600; cursor: pointer; box-shadow: 0 0 22px rgba(120, 230, 200, 0.3);
  }
  button:disabled { opacity: .6; cursor: default; }
  #status { margin: 0; min-height: 1.2em; }
  #status.ok { color: var(--accent); }
  #status.err { color: #ff9a8a; }
</style>
