---
import '../styles/content.css'; // global styles for runtime-rendered cards/posts
interface Props {
  title?: string;
  description?: string;
}
const { title = 'Celebrating Kristin', description = 'Stories, memories, and reflections.' } = Astro.props;
// Keep the footer (its gradient) everywhere, but drop the "Share a memory"
// button on the share page, single memory pages (which have their own nav),
// and the /together info page.
const fp = Astro.url.pathname.replace(/\/$/, '');
const hideShareButton = fp === '/share' || fp === '/memory' || fp === '/together';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <title>{title}</title>

    {/* Favicons — full set covers desktop tabs, iOS home screen, and Android/PWA. */}
    <link rel="icon" href="/img/favicon/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/img/favicon/site.webmanifest" />
    <meta name="theme-color" content="#0a0e1c" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Vujahday+Script&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --ink: #e9ecf6;          /* soft cool white — primary text */
        --soft: #9aa6c9;         /* muted lavender-grey */
        --line: rgba(180, 200, 255, 0.14); /* faint cool hairline */
        --paper: #0a0e1c;        /* deep night (fallback bg) */
        --accent: #7ee8c9;       /* aurora mint-green */
        --accent-2: #b58cf0;     /* aurora violet */
        --card: rgba(22, 28, 52, 0.55); /* translucent night panel */
        --glow: rgba(120, 230, 200, 0.22);
        --maxw: 44rem;
      }
      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        color: var(--ink);
        font-family: Georgia, 'Times New Roman', serif;
        line-height: 1.7;
        font-size: 1.05rem;
        /* Night sky: a few soft stars, three aurora glows up top, deep indigo wash.
           Fixed so it sits still and ethereal as the page scrolls. */
        background-color: #070b18;
        background-image:
          radial-gradient(1.5px 1.5px at 12% 14%, rgba(255, 255, 255, 0.7), transparent),
          radial-gradient(1px 1px at 28% 8%, rgba(255, 255, 255, 0.5), transparent),
          radial-gradient(1px 1px at 47% 18%, rgba(255, 255, 255, 0.55), transparent),
          radial-gradient(1.5px 1.5px at 68% 6%, rgba(255, 255, 255, 0.5), transparent),
          radial-gradient(1px 1px at 83% 16%, rgba(255, 255, 255, 0.45), transparent),
          radial-gradient(1px 1px at 92% 9%, rgba(255, 255, 255, 0.4), transparent),
          radial-gradient(1px 1px at 6% 30%, rgba(255, 255, 255, 0.4), transparent),
          radial-gradient(1.5px 1.5px at 20% 42%, rgba(255, 255, 255, 0.55), transparent),
          radial-gradient(1px 1px at 35% 27%, rgba(255, 255, 255, 0.4), transparent),
          radial-gradient(1px 1px at 44% 55%, rgba(255, 255, 255, 0.38), transparent),
          radial-gradient(1.5px 1.5px at 58% 38%, rgba(255, 255, 255, 0.5), transparent),
          radial-gradient(1px 1px at 72% 50%, rgba(255, 255, 255, 0.42), transparent),
          radial-gradient(1px 1px at 88% 33%, rgba(255, 255, 255, 0.5), transparent),
          radial-gradient(1px 1px at 95% 60%, rgba(255, 255, 255, 0.4), transparent),
          radial-gradient(1px 1px at 15% 68%, rgba(255, 255, 255, 0.42), transparent),
          radial-gradient(1.5px 1.5px at 31% 82%, rgba(255, 255, 255, 0.48), transparent),
          radial-gradient(1px 1px at 50% 73%, rgba(255, 255, 255, 0.38), transparent),
          radial-gradient(1px 1px at 64% 88%, rgba(255, 255, 255, 0.42), transparent),
          radial-gradient(1.5px 1.5px at 79% 70%, rgba(255, 255, 255, 0.5), transparent),
          radial-gradient(1px 1px at 90% 85%, rgba(255, 255, 255, 0.4), transparent),
          radial-gradient(1px 1px at 8% 88%, rgba(255, 255, 255, 0.36), transparent),
          radial-gradient(78% 60% at 14% -10%, rgba(86, 235, 176, 0.38), transparent 70%),
          radial-gradient(70% 54% at 84% -6%, rgba(156, 118, 246, 0.36), transparent 72%),
          radial-gradient(60% 46% at 50% 8%, rgba(78, 200, 236, 0.28), transparent 72%),
          radial-gradient(52% 44% at 36% 16%, rgba(110, 240, 180, 0.20), transparent 74%),
          linear-gradient(to bottom, #0b1330 0%, #0a0e20 50%, #070a16 100%);
        background-attachment: fixed;
        background-repeat: no-repeat;
        /* Sticky footer: column layout where the page content grows to fill the
           viewport, so the footer always sits at the very bottom (no gap below)
           and is off-screen until you scroll down to it. */
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .page { flex: 1 0 auto; }
      a { color: var(--accent); }
      h1 { font-family: 'Vujahday Script', cursive; line-height: .95; }
      .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 1.25rem; }
      /* Full-screen looping background video; the body's aurora gradient shows
         through as a fallback if it can't play. Overlay keeps text legible. */
      .bg-video {
        position: fixed; inset: 0; width: 100%; height: 100%;
        object-fit: cover; z-index: -2; pointer-events: none;
      }
      .bg-overlay {
        position: fixed; inset: 0; z-index: -1; pointer-events: none;
        background: linear-gradient(to bottom, rgba(7, 11, 24, 0.5), rgba(7, 11, 24, 0.62));
      }
      @media (prefers-reduced-motion: reduce) { .bg-video { display: none; } }
      /* Site-wide alert bar — hidden until the admin sets alert text on
         /together. Sticky so the message stays visible; the whole bar links to
         /together. Populated at runtime from /data/together.json. */
      .alert-bar {
        display: block; position: sticky; top: 0; z-index: 40;
        text-align: center; text-decoration: none;
        font-family: -apple-system, system-ui, sans-serif; font-size: .95rem; font-weight: 600;
        padding: .7rem 1.5rem; color: #08111f;
        background: linear-gradient(120deg, #7ee8c9, #8fd0f0);
        /* Soft mint glow + a darker drop shadow beneath so the bar lifts off
           the page content scrolling under it. */
        box-shadow: 0 2px 18px rgba(120, 230, 200, 0.35), 0 6px 16px rgba(0, 0, 0, 0.38);
      }
      .alert-bar::after { content: ' →'; opacity: .8; }
      .alert-bar:hover { filter: brightness(1.04); }
      .alert-bar[hidden] { display: none; }
      .share-cta {
        display: inline-block; margin-top: 1.5rem; padding: .72rem 1.5rem;
        background: linear-gradient(120deg, #7ee8c9, #8fd0f0); color: #08111f;
        text-decoration: none; border-radius: 999px; font-weight: 600;
        font-family: -apple-system, system-ui, sans-serif; font-size: .95rem;
        box-shadow: 0 0 24px rgba(120, 230, 200, 0.35);
      }
      .share-cta:hover { box-shadow: 0 0 34px rgba(120, 230, 200, 0.55); }
      footer.site {
        flex-shrink: 0;
        text-align: center; color: var(--soft); font-size: .85rem;
        padding: 8rem 1.25rem 5.5rem; margin-top: 4rem;
        /* Fade from the night sky down into a deep purple beneath the text. */
        background: linear-gradient(to bottom, transparent, #160a30 85%);
      }
      footer.site a { color: var(--soft); }
      footer.site a.share-cta { color: #08111f; } /* keep the button's dark text */
    </style>
  </head>
  <body>
    <a id="alert-bar" class="alert-bar" href="/together" hidden></a>
    <video class="bg-video" autoplay muted loop playsinline webkit-playsinline preload="auto" aria-hidden="true">
      <source src="/img/background.webm" type="video/webm" />
      <source src="/img/background.mp4" type="video/mp4" />
    </video>
    <div class="bg-overlay" aria-hidden="true"></div>
    <script>
      // iOS/iPadOS Safari doesn't reliably honor the `muted`+`autoplay`
      // attributes for inline autoplay, and paints a faint play-button glyph
      // over any <video> that isn't playing — visible here through the content
      // since the video sits at z-index:-2. Force play from JS (WebKit needs
      // `muted` set on the property, not just the attribute). If it still can't
      // start — Low Power Mode, an unsupported codec — hide the element so only
      // the body's aurora gradient shows (no glyph), and try once more on the
      // first touch, revealing it again if that succeeds.
      const v = document.querySelector('.bg-video');
      if (v instanceof HTMLVideoElement) {
        v.muted = true;
        v.playsInline = true;
        const hide = () => { v.style.display = 'none'; };
        const playOnGesture = () => {
          const retry = () => { v.style.display = ''; v.play().catch(hide); };
          window.addEventListener('touchstart', retry, { once: true, passive: true });
          window.addEventListener('pointerdown', retry, { once: true });
        };
        const tryPlay = () => {
          const p = v.play();
          if (p && typeof p.then === 'function') p.catch(() => { hide(); playOnGesture(); });
        };
        v.addEventListener('error', hide);
        if (v.readyState >= 2) tryPlay();
        else v.addEventListener('loadeddata', tryPlay, { once: true });
      }
    </script>
    <script>
      // Show the alert bar only when the admin has set alert text on /together.
      // Plain text (textContent), so the alert can never inject markup.
      const bar = document.getElementById('alert-bar');
      // Don't show the bar on the page it links to — you're already there.
      const onTogether = location.pathname.replace(/\/$/, '') === '/together';
      if (bar && !onTogether) {
        fetch('/data/together.json', { cache: 'no-store' })
          .then((r) => (r.ok ? r.json() : null))
          .then((d) => {
            const text = d && typeof d.alert === 'string' ? d.alert.trim() : '';
            if (!text) return;
            bar.textContent = text;
            bar.hidden = false;
          })
          .catch(() => {});
      }
    </script>
    <div class="page"><slot /></div>
    <footer class="site">
      <div class="wrap">
        {!hideShareButton && <a class="share-cta" href="/share">Share a memory</a>}
      </div>
    </footer>
  </body>
</html>
